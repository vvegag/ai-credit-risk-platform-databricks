{
  "datasets": [
    {
      "name": "ds_clientes_criticos",
      "displayName": "Clientes Críticos",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT codigo_cliente) as total_criticos\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia\n",
        "WHERE\n",
        "  classe_risco = 'Crítico'"
      ]
    },
    {
      "name": "ds_performance_modelo",
      "displayName": "Performance do Modelo",
      "queryLines": [
        "SELECT\n",
        "  classe_risco,\n",
        "  COUNT(*) as total_predicoes\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia\n",
        "GROUP BY\n",
        "  classe_risco\n",
        "ORDER BY\n",
        "  CASE classe_risco\n",
        "    WHEN 'Baixo' THEN 1\n",
        "    WHEN 'Médio' THEN 2\n",
        "    WHEN 'Alto' THEN 3\n",
        "    WHEN 'Crítico' THEN 4\n",
        "  END"
      ]
    },
    {
      "name": "ds_trend_inadimplencia",
      "displayName": "Trend Inadimplência Mensal",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('month', data_vencimento) as mes,\n",
        "  SUM(\n",
        "    CASE\n",
        "      WHEN status_enriquecido = 'Inadimplente' THEN 1\n",
        "      ELSE 0\n",
        "    END\n",
        "  )\n",
        "    * 100.0\n",
        "    / COUNT(*) as taxa_inadimplencia_pct\n",
        "FROM\n",
        "  workspace.risco_silver.faturas_enriquecidas\n",
        "WHERE\n",
        "  data_vencimento >= :data_inicio\n",
        "  AND data_vencimento <= :data_fim\n",
        "GROUP BY\n",
        "  DATE_TRUNC('month', data_vencimento)\n",
        "ORDER BY\n",
        "  mes"
      ],
      "parameters": [
        {
          "displayName": "Data Início",
          "keyword": "data_inicio",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2025-01-01"
                }
              ]
            }
          }
        },
        {
          "displayName": "Data Fim",
          "keyword": "data_fim",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2026-12-31"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ds_taxa_inadimplencia",
      "displayName": "Taxa de Inadimplência",
      "queryLines": [
        "SELECT\n",
        "  AVG(prob_inadimplente) * 100 as taxa_inadimplencia_pct\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia"
      ]
    },
    {
      "name": "ds_valor_risco",
      "displayName": "Valor Total em Risco",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_em_aberto) as valor_total_risco\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia\n",
        "WHERE\n",
        "  classe_risco = 'Crítico'"
      ]
    },
    {
      "name": "ds_distribuicao_risco",
      "displayName": "Distribuição por Risco",
      "queryLines": [
        "SELECT\n",
        "  classe_risco,\n",
        "  COUNT(DISTINCT codigo_cliente) as total_clientes\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia\n",
        "GROUP BY\n",
        "  classe_risco\n",
        "ORDER BY\n",
        "  CASE classe_risco\n",
        "    WHEN 'Baixo' THEN 1\n",
        "    WHEN 'Médio' THEN 2\n",
        "    WHEN 'Alto' THEN 3\n",
        "    WHEN 'Crítico' THEN 4\n",
        "  END"
      ]
    },
    {
      "name": "ds_cashflow_evolucao",
      "displayName": "Evolução Cashflow",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('month', data_vencimento) as data,\n",
        "  SUM(valor_titulo) as valor_previsto\n",
        "FROM\n",
        "  workspace.risco_silver.faturas_enriquecidas\n",
        "WHERE\n",
        "  data_vencimento IS NOT NULL\n",
        "  AND data_vencimento >= :data_inicio\n",
        "  AND data_vencimento <= :data_fim\n",
        "GROUP BY\n",
        "  DATE_TRUNC('month', data_vencimento)\n",
        "ORDER BY\n",
        "  data"
      ],
      "parameters": [
        {
          "displayName": "Data Início",
          "keyword": "data_inicio",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2025-01-01"
                }
              ]
            }
          }
        },
        {
          "displayName": "Data Fim",
          "keyword": "data_fim",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2026-12-31"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ds_top10_risco",
      "displayName": "Top 10 Clientes de Risco",
      "queryLines": [
        "SELECT\n",
        "  p.codigo_cliente,\n",
        "  p.nome_cliente as razao_social,\n",
        "  p.prob_inadimplente as probabilidade_inadimplencia,\n",
        "  p.classe_risco as categoria_risco,\n",
        "  p.total_em_aberto as valor_em_aberto\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia p\n",
        "ORDER BY\n",
        "  p.prob_inadimplente DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "ds_validacao_notas",
      "displayName": "Validação de Notas",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN status_enriquecido = 'Pago' THEN 'Aprovado'\n",
        "    WHEN status_enriquecido = 'Pendente' THEN 'Pendente'\n",
        "    ELSE 'Rejeitado'\n",
        "  END as status_validacao,\n",
        "  COUNT(*) as total_notas\n",
        "FROM\n",
        "  workspace.risco_silver.faturas_enriquecidas\n",
        "WHERE\n",
        "  data_vencimento >= :data_inicio\n",
        "  AND data_vencimento <= :data_fim\n",
        "GROUP BY\n",
        "  status_validacao"
      ],
      "parameters": [
        {
          "displayName": "Data Início",
          "keyword": "data_inicio",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2025-01-01"
                }
              ]
            }
          }
        },
        {
          "displayName": "Data Fim",
          "keyword": "data_fim",
          "dataType": "DATE",
          "defaultSelection": {
            "values": {
              "dataType": "DATE",
              "values": [
                {
                  "value": "2026-12-31"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ds_receita_prevista",
      "displayName": "Receita Prevista 30 Dias",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_em_aberto) * 0.85 as receita_prevista_30d\n",
        "FROM\n",
        "  workspace.risco_gold.predicoes_inadimplencia\n",
        "WHERE\n",
        "  classe_risco IN ('Baixo', 'Médio')"
      ]
    }
  ],
